# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Clinic Info ──────────────────────────────────────────────────────────────
CLINIC_NAME=Luxe Medical Spa
CLINIC_PHONE=+15551234567

# ─── Google Calendar ──────────────────────────────────────────────────────────
# Get from Google Cloud Console → Service Account → JSON key
# Download the JSON and save as google-credentials.json in project root
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# ─── Twilio (SMS confirmations) ───────────────────────────────────────────────
# Get from twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+15557654321

# ─── Retell AI ────────────────────────────────────────────────────────────────
# Your Retell API key (for reference — Retell calls your server, not the other way)
RETELL_API_KEY=key_xxxxxxxxxxxxxxxx
